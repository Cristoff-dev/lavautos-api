generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ENUMS
// ==========================================
enum RolUsuario {
  ADMIN
  CAJERO
  SUPERVISOR
  LAVADOR
}

enum EstadoProceso {
  EN_ESPERA
  EN_LAVADO
  LISTO
  ENTREGADO_Y_PAGADO
}

enum CategoriaContable {
  INGRESO_LAVADO
  GASTO_OPERATIVO
  PAGO_COMISION
  COMPRA_INSUMO
}

// ==========================================
// 2. CLIENTES (Dueños y Afiliados)
// ==========================================
model Cliente {
  id        Int            @id @default(autoincrement())
  cedula    String         @unique
  nombre    String
  telefono  String
  
  // Relación: Carros de los que soy dueño (ADN)
  propiedades TipoVehiculo[] @relation("Propietario")
  
  // Relación: Veces que he traído un carro (mío o ajeno) a lavar (Operación)
  conducciones Vehiculo[]    @relation("ConductorActivo")
}

// ==========================================
// 3. TIPO_VEHICULOS (Ficha Técnica / ADN)
// ==========================================
model TipoVehiculo {
  id        Int      @id @default(autoincrement())
  placa     String   @unique
  marca     String
  modelo    String
  color     String
  clase     String   // Ej: Sedan, SUV, Moto
  
  // El Dueño del carro
  clienteId Int
  cliente   Cliente  @relation("Propietario", fields: [clienteId], references: [id])
  
  // Historial de entradas a la cola de lavado
  entradas  Vehiculo[] 
}

// ==========================================
// 4. VEHICULOS (Operación / Cola de Lavado)
// ==========================================
model Vehiculo {
  id              Int           @id @default(autoincrement())
  fechaIngreso    DateTime      @default(now())
  estado          EstadoProceso @default(EN_ESPERA) // Rojo, Amarillo, Verde
  estadoVisual    String?       
  
  // Referencia al ADN del carro
  tipoVehiculoId  Int
  adn             TipoVehiculo  @relation(fields: [tipoVehiculoId], references: [id])
  
  // Quien trae el carro hoy (Puede ser el dueño o un afiliado)
  conductorId     Int
  conductor       Cliente       @relation("ConductorActivo", fields: [conductorId], references: [id])
  
  // Asignación de Pista
  lavadorId       Int?
  lavador         Usuario?      @relation("LavadorAsignado", fields: [lavadorId], references: [id])
  
  // Finanzas del servicio actual
  montoTotal      Float         @default(0)
  comisionLavador Float         @default(0) // El 25%
  
  servicios       DetalleServicio[]
  transacciones   TransaccionContable[]
}

// ==========================================
// 5. PROVEEDORES, COMPRAS Y GASTOS
// ==========================================
model Proveedor {
  id      Int      @id @default(autoincrement())
  rif     String   @unique
  nombre  String
  compras Compra[]
}

model Compra {
  id            Int             @id @default(autoincrement())
  fecha         DateTime        @default(now())
  total         Float
  proveedorId   Int
  proveedor     Proveedor       @relation(fields: [proveedorId], references: [id])
  detalles      DetalleCompra[]
  transaccionId Int?            @unique
  transaccion   TransaccionContable? @relation(fields: [transaccionId], references: [id])
}

model GastoOperativo {
  id            Int      @id @default(autoincrement())
  concepto      String   
  monto         Float
  fecha         DateTime @default(now())
  transaccionId Int?     @unique
  transaccion   TransaccionContable? @relation(fields: [transaccionId], references: [id])
}

// ==========================================
// 6. SERVICIOS E INVENTARIO
// ==========================================
model Servicio {
  id           Int               @id @default(autoincrement())
  nombre       String            @unique
  precio       Float
  esCombo      Boolean           @default(false)
  detalles     DetalleServicio[]
  dosificacion ServicioInsumo[]
}

model DetalleServicio {
  id         Int      @id @default(autoincrement())
  vehiculoId Int
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id])
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  precioFijo Float    
}

model Insumo {
  id          Int              @id @default(autoincrement())
  nombre      String           @unique
  stockActual Float
  stockMinimo Float
  servicios   ServicioInsumo[]
  compras     DetalleCompra[]
}

model ServicioInsumo {
  id         Int      @id @default(autoincrement())
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  insumoId   Int
  insumo     Insumo   @relation(fields: [insumoId], references: [id])
  cantidad   Float
}

model DetalleCompra {
  id         Int    @id @default(autoincrement())
  compraId   Int
  compra     Compra @relation(fields: [compraId], references: [id])
  insumoId   Int
  insumo     Insumo @relation(fields: [insumoId], references: [id])
  cantidad   Float
  precioUnit Float
}

// ==========================================
// 7. CONTABILIDAD Y RRHH
// ==========================================
model TransaccionContable {
  id          Int               @id @default(autoincrement())
  fecha       DateTime          @default(now())
  categoria   CategoriaContable
  monto       Float             
  descripcion String
  
  vehiculoId  Int?
  vehiculo    Vehiculo?         @relation(fields: [vehiculoId], references: [id])
  compra      Compra?
  gasto       GastoOperativo?
}

model Usuario {
  id             Int        @id @default(autoincrement())
  nombre         String
  email          String     @unique
  password       String
  rol            RolUsuario @default(CAJERO)
  activo         Boolean    @default(true)
  ordenesLavadas Vehiculo[] @relation("LavadorAsignado")
}