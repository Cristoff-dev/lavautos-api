generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ENUMS (RBAC, Estados y Tipos)
// ==========================================
enum RolUsuario {
  ADMIN
  CAJERO
  SUPERVISOR
  LAVADOR
}

enum TipoVehiculo {
  SEDAN
  CAMIONETA
  MOTO
  CAMION
}

enum EstadoOrden {
  EN_ESPERA
  EN_LAVADO
  LISTO
  PAGADO_Y_ENTREGADO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  PAGO_MOVIL
  POR_DEFINIR
}

enum TipoTransaccion {
  INGRESO_LAVADO
  PAGO_COMISION
  COMPRA_INSUMO
  GASTO_FIJO
}

// ==========================================
// 2. USUARIOS Y VEHÍCULOS
// ==========================================
model Usuario {
  id             Int              @id @default(autoincrement())
  nombre         String
  email          String           @unique
  password       String
  rol            RolUsuario       @default(CAJERO)
  activo         Boolean          @default(true)
  ordenesLavadas OrdenDeTrabajo[] @relation("LavadorAsignado")
}

model Vehiculo {
  id        Int              @id @default(autoincrement())
  placa     String           @unique
  tipo      TipoVehiculo
  historial OrdenDeTrabajo[]
}

// ==========================================
// 3. CATÁLOGO E INVENTARIO
// ==========================================
model Servicio {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  precio      Float
  descripcion String? // <--- AGREGA ESTA LÍNEA (el ? lo hace opcional)
  esCombo     Boolean @default(false)
  activo      Boolean @default(true)

  detalles DetalleOrden[]
  dosificacion   ServicioInsumo[]
}

model Insumo {
  id          Int    @id @default(autoincrement())
  nombre      String @unique
  unidad      String
  stockActual Float
  stockMinimo Float

  servicios ServicioInsumo[]
}

model ServicioInsumo {
  id         Int      @id @default(autoincrement())
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  insumoId   Int
  insumo     Insumo   @relation(fields: [insumoId], references: [id])
  cantidad   Float
}

// ==========================================
// 4. OPERACIONES Y CAJA
// ==========================================
model OrdenDeTrabajo {
  id           Int         @id @default(autoincrement())
  fechaIngreso DateTime    @default(now())
  estado       EstadoOrden @default(EN_ESPERA)
  estadoVisual String?

  vehiculoId Int
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id])

  lavadorId Int?
  lavador   Usuario? @relation("LavadorAsignado", fields: [lavadorId], references: [id])

  subtotal        Float      @default(0)
  comisionLavador Float      @default(0)
  metodoPago      MetodoPago @default(POR_DEFINIR)

  detalles      DetalleOrden[]
  transacciones TransaccionContable[]
}

model DetalleOrden {
  id         Int            @id @default(autoincrement())
  ordenId    Int
  orden      OrdenDeTrabajo @relation(fields: [ordenId], references: [id])
  servicioId Int
  servicio   Servicio       @relation(fields: [servicioId], references: [id])
  precioFijo Float
}

// ==========================================
// 5. CONTABILIDAD
// ==========================================
model TransaccionContable {
  id          Int             @id @default(autoincrement())
  fecha       DateTime        @default(now())
  tipo        TipoTransaccion
  monto       Float
  descripcion String

  ordenId Int?
  orden   OrdenDeTrabajo? @relation(fields: [ordenId], references: [id])
}

model Provider {
  id          String   @id @default(uuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  isActive    Boolean  @default(true)
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  isActive    Boolean  @default(true)
}
