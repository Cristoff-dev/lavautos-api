generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ENUMS
// ==========================================
enum RolUsuario {
  ADMIN
  CAJERO
  SUPERVISOR
  LAVADOR
}

enum EstadoProceso {
  EN_ESPERA
  EN_LAVADO
  LISTO
  ENTREGADO_Y_PAGADO
}

enum CategoriaContable {
  INGRESO_LAVADO
  GASTO_OPERATIVO
  PAGO_COMISION
  COMPRA_INSUMO
}

// ==========================================
// 2. CLIENTES (Dueños y Afiliados)
// ==========================================
model Cliente {
  id           Int            @id @default(autoincrement())
  cedula       String         @unique
  nombre       String
  telefono     String
  email        String?
  activo       Boolean        @default(true)

  propiedades  TipoVehiculo[] @relation("Propietario")
  conducciones Vehiculo[]     @relation("ConductorActivo")

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// ==========================================
// 3. TIPO_VEHICULOS (Ficha Técnica / ADN)
// ==========================================
model TipoVehiculo {
  id        Int      @id @default(autoincrement())
  placa     String   @unique
  marca     String
  modelo    String
  color     String
  clase     String   // Ej: Sedan, SUV, Moto
  activo    Boolean  @default(true) // <-- Soft Delete

  clienteId Int
  cliente   Cliente  @relation("Propietario", fields: [clienteId], references: [id])
  
  entradas  Vehiculo[]

  createdAt DateTime @default(now()) // <-- Auditoría
  updatedAt DateTime @updatedAt      // <-- Auditoría
}

// ==========================================
// 4. VEHICULOS (Operación / Cola de Lavado)
// ==========================================
model Vehiculo {
  id              Int           @id @default(autoincrement())
  fechaIngreso    DateTime      @default(now())
  estado          EstadoProceso @default(EN_ESPERA)
  estadoVisual    String?       
  
  tipoVehiculoId  Int
  adn             TipoVehiculo  @relation(fields: [tipoVehiculoId], references: [id])
  
  conductorId     Int
  conductor       Cliente       @relation("ConductorActivo", fields: [conductorId], references: [id])
  
  lavadorId       Int?
  lavador         Usuario?      @relation("LavadorAsignado", fields: [lavadorId], references: [id])
  
  montoTotal      Float         @default(0)
  comisionLavador Float         @default(0)
  
  servicios       DetalleServicio[]
  transacciones   TransaccionContable[]

  updatedAt       DateTime      @updatedAt // <-- Para saber cuándo cambió de estado
}

// ==========================================
// 5. PROVEEDORES, COMPRAS Y GASTOS
// ==========================================
model Proveedor {
  id        Int      @id @default(autoincrement())
  rif       String   @unique
  nombre    String
  telefono  String?  // <-- Contacto
  email     String?  // <-- Contacto
  activo    Boolean  @default(true) // <-- Soft Delete

  compras   Compra[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Compra {
  id            Int           @id @default(autoincrement())
  fecha         DateTime      @default(now())
  total         Float
  proveedorId   Int
  proveedor     Proveedor     @relation(fields: [proveedorId], references: [id])
  detalles      DetalleCompra[]
  transaccionId Int?          @unique
  transaccion   TransaccionContable? @relation(fields: [transaccionId], references: [id])
  
  updatedAt     DateTime      @updatedAt
}

model GastoOperativo {
  id            Int      @id @default(autoincrement())
  concepto      String   
  monto         Float
  fecha         DateTime @default(now())
  transaccionId Int?     @unique
  transaccion   TransaccionContable? @relation(fields: [transaccionId], references: [id])

  updatedAt     DateTime @updatedAt
}

// ==========================================
// 6. SERVICIOS E INVENTARIO
// ==========================================
model Servicio {
  id               Int     @id @default(autoincrement())
  nombre           String  @unique
  precio           Float
  descripcion      String?
  duracionMinutos  Int?
  esCombo          Boolean @default(false)
  activo           Boolean @default(true)
  tipoVehiculo     String  @default("SEDAN")

  detalles     DetalleServicio[]
  dosificacion ServicioInsumo[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Insumo {
  id           Int              @id @default(autoincrement())
  nombre       String           @unique
  stockActual  Float
  stockMinimo  Float
  activo       Boolean          @default(true) // <-- Soft Delete

  servicios    ServicioInsumo[]
  compras      DetalleCompra[]

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// Los modelos de relación (Tablas Pivot) usualmente no necesitan auditoría completa
model DetalleServicio {
  id         Int      @id @default(autoincrement())
  vehiculoId Int
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id])
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  precioFijo Float    
}

model ServicioInsumo {
  id         Int      @id @default(autoincrement())
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  insumoId   Int
  insumo     Insumo   @relation(fields: [insumoId], references: [id])
  cantidad   Float
}

model DetalleCompra {
  id         Int    @id @default(autoincrement())
  compraId   Int
  compra     Compra @relation(fields: [compraId], references: [id])
  insumoId   Int
  insumo     Insumo @relation(fields: [insumoId], references: [id])
  cantidad   Float
  precioUnit Float
}

// ==========================================
// 7. CONTABILIDAD Y RRHH
// ==========================================
model TransaccionContable {
  id          Int               @id @default(autoincrement())
  fecha       DateTime          @default(now())
  categoria   CategoriaContable
  monto       Float             
  descripcion String
  
  vehiculoId  Int?
  vehiculo    Vehiculo?         @relation(fields: [vehiculoId], references: [id])
  compra      Compra?
  gasto       GastoOperativo?
}

model Usuario {
  id             Int        @id @default(autoincrement())
  nombre         String
  username          String     @unique
  password       String
  rol            RolUsuario @default(CAJERO)
  activo         Boolean    @default(true)
  ordenesLavadas Vehiculo[] @relation("LavadorAsignado")

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Provider {
  id          String   @id @default(uuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  isActive    Boolean  @default(true)
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  isActive    Boolean  @default(true)
}
